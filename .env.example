# Copier en .env pour une execution locale (hors Docker).
# Dans Docker, ces valeurs sont fournies par docker-compose.yml.

# UID utilise par les conteneurs Airflow (Linux : `id -u`).
AIRFLOW_UID=50000

# --- MongoDB : referentiel entreprises + State DB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=bce
MONGO_COMPANIES=companies
MONGO_STATE=ingestion_state

# --- HDFS (Bronze) ---
HDFS_URL=http://localhost:9870
HDFS_USER=root
BRONZE_ROOT=/data/raw

# --- Fenetre d'annees pour les comptes annuels NBB/CBSO ---
YEAR_MIN=2021
YEAR_MAX=2025

# --- Rotation Tor (anti-blocage du scraping) ---
USE_TOR=false
TOR_PROXIES=socks5h://localhost:9050,socks5h://localhost:9052,socks5h://localhost:9054
TOR_CONTROL_HOSTS=localhost
TOR_CONTROL_PASSWORD=mypass

# --- Notaire / stapor ---
# Cookie fourni directement (sinon acquis via Playwright).
COOKIE_NOTAIRE=
